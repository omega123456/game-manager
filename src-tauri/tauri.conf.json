{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Game Manager",
  "version": "2.0.4",
  "identifier": "app.gamemanager.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Game Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$PICTURE/**",
          "$DOWNLOAD/**",
          "$DOCUMENT/**",
          "$HOME/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "copyright": "Copyright (C) 2026 omega123456",
    "license": "GPL-3.0-or-later",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/omega123456/game-manager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU1N0QyQzZENDE5REVDQUEKUldTcTdKMUJiU3g5VlVraXptOGt3SERuMXQ2aWYrcnArWDJKQWp4ZEtPbEZYK25DdGhzbEc4REMK"
    }
  }
}
