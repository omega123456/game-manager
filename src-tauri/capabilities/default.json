{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "allow-log-frontend",
    "allow-list-games",
    "allow-get-game",
    "allow-create-game",
    "allow-update-game",
    "allow-delete-game",
    "allow-set-game-groups",
    "allow-set-game-scripts",
    "allow-search-art",
    "allow-fetch-metadata",
    "allow-cache-art-candidate",
    "allow-get-all-settings",
    "allow-get-setting",
    "allow-set-setting"
  ]
}
